{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "printWidth": 180,
    "endOfLine": "lf",
    "semi": true,
    "singleQuote": false,
    "jsxSingleQuote": false,
    "tabWidth": 4,
    "useTabs": false,
    "trailingComma": "all",
    "bracketSpacing": true,
    "bracketSameLine": false,
    "arrowParens": "always",
    "ignorePatterns": [".oxfmtrc.json"]
}
