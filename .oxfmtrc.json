{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "printWidth": 180,
    "endOfLine": "lf",
    "semi": true,
    "singleQuote": false,
    "tabWidth": 4,
    "useTabs": false,
    "trailingComma": "all",
    "bracketSpacing": true,
    "bracketSameLine": false,
    "arrowParens": "always",
    "ignorePatterns": [
        "node_modules/**",
        "vendor/**",
        "dist/**",
        "build/**",
        "coverage/**",
        ".turbo/**",
        ".pnpm-store/**",
        "apps/*/src/routeTree.gen.ts",
        "apps/*/dist/**",
        "apps/mobile/android/**",
        "apps/mobile/ios/**",
        "apps/mobile/.expo/**",
        "packages/*/dist/**",
        "packages/*/build/**"
    ]
}
