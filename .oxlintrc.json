{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "extends": ["./oxlintrc.shared.json"],
    "ignorePatterns": [
        "node_modules/**",
        "vendor/**",
        "dist/**",
        "build/**",
        "coverage/**",
        ".turbo/**",
        ".pnpm-store/**",
        "apps/*/dist/**",
        "apps/mobile/android/**",
        "apps/mobile/ios/**",
        "apps/mobile/.expo/**",
        "packages/*/dist/**",
        "packages/*/build/**"
    ]
}
