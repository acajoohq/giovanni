{
    "name": "web",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "clean": "rm -rf dist .output",
        "dev": "vite --host 0.0.0.0",
        "format": "oxfmt --write src public vite.config.ts package.json tsconfig.json .oxlintrc.json",
        "format:check": "oxfmt --check src public vite.config.ts package.json tsconfig.json .oxlintrc.json",
        "lint": "oxlint src vite.config.ts",
        "preview": "vite preview",
        "start": "node .output/server/index.mjs",
        "test": "vitest run --passWithNoTests",
        "test:watch": "vitest",
        "typecheck": "tsgo --noEmit",
        "validate": "pnpm run typecheck"
    },
    "dependencies": {
        "@base-ui/react": "^1.4.1",
        "@fontsource-variable/inter": "^5.2.8",
        "@fontsource-variable/roboto-slab": "^5.2.8",
        "@pdfly/pdf-render": "workspace:*",
        "@pdfly/wasm": "workspace:*",
        "@remixicon/react": "^4.9.0",
        "@tanstack/react-router": "^1.169.2",
        "@tanstack/react-start": "^1.167.64",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "fflate": "^0.8.2",
        "i18next": "^26.0.10",
        "pdfjs-dist": "^5.7.284",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-i18next": "^17.0.7",
        "react-resizable-panels": "^4.11.0",
        "shadcn": "^4.7.0",
        "tailwind-merge": "^3.5.0",
        "tw-animate-css": "^1.4.0"
    },
    "devDependencies": {
        "@rolldown/plugin-babel": "^0.2.3",
        "@tailwindcss/vite": "^4.2.4",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@typescript/native-preview": "7.0.0-dev.20260505.1",
        "@vitejs/plugin-react": "^6.0.1",
        "babel-plugin-react-compiler": "^1.0.0",
        "code-inspector-plugin": "^1.5.1",
        "oxfmt": "catalog:",
        "oxlint": "catalog:",
        "tailwindcss": "^4.2.4",
        "typescript": "^6.0.3",
        "vite": "^8.0.10",
        "vitest": "^4.1.5"
    },
    "engines": {
        "node": ">=24.0.0"
    }
}
