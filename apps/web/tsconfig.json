{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "jsx": "react-jsx",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "noEmit": true,
        "types": ["vite/client"],
        "paths": {
            "@/*": ["./src/*"],
            "@/components/*": ["./src/components/*"],
            "@/constants/*": ["./src/constants/*"],
            "@/hooks/*": ["./src/hooks/*"],
            "@/lib/*": ["./src/lib/*"],
            "@/routes/*": ["./src/routes/*"],
            "@/styles/*": ["./src/styles/*"],
            "@/utils/*": ["./src/utils/*"]
        }
    },
    "include": ["src", "@pdfly", "vite.config.ts", "../../packages/pdf-render/src/pdfjs/pdfjs-dist.d.ts"]
}
