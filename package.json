{
  "name": "@qpdf/wasm",
  "version": "0.1.0",
  "description": "Modern WebAssembly build of qpdf for PDF compression and manipulation",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./wasm": "./dist/qpdf.wasm"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist build",
    "build:wasm": "cd wasm && bash build.sh",
    "build:lib": "tsdown",
    "build": "npm run build:wasm && npm run build:lib",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint src",
    "format": "oxlint --fix src",
    "demo": "vite demo --open",
    "validate": "publint",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "qpdf",
    "pdf",
    "compression",
    "wasm",
    "webassembly",
    "pdf-processing"
  ],
  "author": "qpdf contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/qpdf/qpdf.git"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "oxlint": "^0.16.1",
    "publint": "^0.2.12",
    "tsdown": "^0.20.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-wasm": "^3.3.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
