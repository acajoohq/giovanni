{
  "name": "pdfly",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "clean": "turbo clean",
    "dev": "turbo dev --filter=pdfly-web",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "typecheck": "turbo typecheck",
    "validate": "turbo validate"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "publint": "^0.3.18",
    "tsdown": "^0.21.10",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
