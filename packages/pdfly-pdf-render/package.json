{
    "name": "@pdfly/pdf-render",
    "version": "0.1.0",
    "description": "PDF.js-based page rasterisation to JPEG (browser and Node with optional canvas)",
    "keywords": ["jpg", "pdf", "pdf.js", "pdf-render", "rasterize"],
    "homepage": "https://github.com/MatteoGauthier/qpdf-wasm#readme",
    "bugs": {
        "url": "https://github.com/MatteoGauthier/qpdf-wasm/issues"
    },
    "license": "Apache-2.0",
    "author": "pdfly contributors",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/MatteoGauthier/qpdf-wasm.git",
        "directory": "packages/pdfly-pdf-render"
    },
    "files": ["dist", "README.md"],
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "source": "./src/index.ts",
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "publishConfig": {
        "exports": {
            ".": {
                "import": {
                    "types": "./dist/index.d.mts",
                    "default": "./dist/index.mjs"
                },
                "require": {
                    "types": "./dist/index.d.cts",
                    "default": "./dist/index.cjs"
                }
            }
        }
    },
    "scripts": {
        "build": "pnpm run build:lib",
        "build:lib": "tsdown",
        "clean": "rm -rf dist",
        "format": "oxfmt --write src tsdown.config.ts package.json tsconfig.json",
        "format:check": "oxfmt --check src tsdown.config.ts package.json tsconfig.json",
        "lint": "oxlint src tsdown.config.ts",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "validate": "publint",
        "package:check": "pnpm run build:lib && pnpm run validate && pnpm pack --dry-run"
    },
    "dependencies": {
        "pdfjs-dist": "^5.7.284"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "oxfmt": "^0.48.0",
        "oxlint": "^1.63.0",
        "publint": "^0.3.19",
        "tsdown": "^0.21.10",
        "typescript": "^6.0.3"
    },
    "peerDependencies": {
        "canvas": "^3.2.3"
    },
    "peerDependenciesMeta": {
        "canvas": {
            "optional": true
        }
    },
    "engines": {
        "node": ">=24.0.0"
    }
}
