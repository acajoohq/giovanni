{
    "name": "@giovanni/pdf-render",
    "version": "0.1.0",
    "description": "PDF.js-based page rasterisation to JPEG (browser and Node with optional canvas)",
    "keywords": [
        "jpg",
        "pdf",
        "pdf-render",
        "pdf.js",
        "rasterize"
    ],
    "homepage": "https://github.com/MatteoGauthier/qpdf-wasm#readme",
    "bugs": {
        "url": "https://github.com/MatteoGauthier/qpdf-wasm/issues"
    },
    "license": "Apache-2.0",
    "author": "pdfly contributors",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/MatteoGauthier/qpdf-wasm.git",
        "directory": "packages/pdfly-pdf-render"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "type": "module",
    "sideEffects": [
        "./dist/pdfjs.browser.mjs",
        "./dist/pdfjsLegacy.browser.mjs",
        "./src/pdfjs/browser.ts",
        "./src/pdfjs/legacy.browser.ts"
    ],
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "source": "./src/index.ts",
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./pdfjs/browser": {
            "source": "./src/pdfjs/browser.ts",
            "import": {
                "types": "./dist/pdfjs.browser.d.mts",
                "default": "./dist/pdfjs.browser.mjs"
            },
            "require": {
                "types": "./dist/pdfjs.browser.d.cts",
                "default": "./dist/pdfjs.browser.cjs"
            }
        },
        "./pdfjs-legacy/browser": {
            "source": "./src/pdfjs/legacy.browser.ts",
            "import": {
                "types": "./dist/pdfjsLegacy.browser.d.mts",
                "default": "./dist/pdfjsLegacy.browser.mjs"
            },
            "require": {
                "types": "./dist/pdfjsLegacy.browser.d.cts",
                "default": "./dist/pdfjsLegacy.browser.cjs"
            }
        }
    },
    "publishConfig": {
        "exports": {
            ".": {
                "import": {
                    "types": "./dist/index.d.mts",
                    "default": "./dist/index.mjs"
                },
                "require": {
                    "types": "./dist/index.d.cts",
                    "default": "./dist/index.cjs"
                }
            },
            "./pdfjs/browser": {
                "import": {
                    "types": "./dist/pdfjs.browser.d.mts",
                    "default": "./dist/pdfjs.browser.mjs"
                },
                "require": {
                    "types": "./dist/pdfjs.browser.d.cts",
                    "default": "./dist/pdfjs.browser.cjs"
                }
            },
            "./pdfjs-legacy/browser": {
                "import": {
                    "types": "./dist/pdfjsLegacy.browser.d.mts",
                    "default": "./dist/pdfjsLegacy.browser.mjs"
                },
                "require": {
                    "types": "./dist/pdfjsLegacy.browser.d.cts",
                    "default": "./dist/pdfjsLegacy.browser.cjs"
                }
            }
        }
    },
    "scripts": {
        "build": "pnpm run build:lib",
        "build:lib": "tsdown",
        "clean": "rm -rf dist",
        "format": "oxfmt --write src tsdown.config.ts package.json tsconfig.json",
        "format:check": "oxfmt --check src tsdown.config.ts package.json tsconfig.json",
        "lint": "oxlint src tsdown.config.ts",
        "typecheck": "tsgo --noEmit",
        "validate": "publint",
        "package:check": "pnpm run build:lib && pnpm run validate && pnpm pack --dry-run"
    },
    "dependencies": {
        "pdfjs-dist": "^5.7.284"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "@typescript/native-preview": "7.0.0-dev.20260505.1",
        "oxfmt": "^0.48.0",
        "oxlint": "^1.63.0",
        "publint": "^0.3.19",
        "tsdown": "^0.21.10",
        "typescript": "^6.0.3"
    },
    "peerDependencies": {
        "canvas": "^3.2.3"
    },
    "peerDependenciesMeta": {
        "canvas": {
            "optional": true
        }
    },
    "engines": {
        "node": ">=24.0.0"
    }
}
