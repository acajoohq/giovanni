{
    "name": "@pdfly/wasm",
    "version": "0.1.0",
    "description": "Modern WebAssembly build of qpdf for PDF compression and manipulation",
    "keywords": [
        "compression",
        "pdf",
        "pdf-processing",
        "qpdf",
        "wasm",
        "webassembly"
    ],
    "homepage": "https://github.com/MatteoGauthier/qpdf-wasm#readme",
    "bugs": {
        "url": "https://github.com/MatteoGauthier/qpdf-wasm/issues"
    },
    "license": "Apache-2.0",
    "author": "qpdf contributors",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/MatteoGauthier/qpdf-wasm.git",
        "directory": "packages/pdfly-wasm"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "scripts": {
        "build": "pnpm run build:wasm && pnpm run build:lib",
        "build:lib": "tsdown",
        "build:wasm": "node scripts/build-wasm.mjs",
        "clean": "rm -rf dist build",
        "format": "oxfmt --write src tsdown.config.ts vitest.config.ts",
        "format:check": "oxfmt --check src tsdown.config.ts vitest.config.ts",
        "lint": "oxlint src tsdown.config.ts vitest.config.ts",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest",
        "typecheck": "tsgo --noEmit",
        "validate": "publint && attw --pack . --profile node16",
        "package:check": "pnpm run validate && pnpm pack --dry-run"
    },
    "engines": {
        "node": ">=24.0.0"
    }
}
