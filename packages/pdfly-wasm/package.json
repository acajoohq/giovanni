{
    "name": "@pdfly/wasm",
    "version": "0.1.0",
    "description": "Modern WebAssembly build of qpdf for PDF compression and manipulation",
    "keywords": [
        "compression",
        "pdf",
        "pdf-processing",
        "qpdf",
        "wasm",
        "webassembly"
    ],
    "license": "Apache-2.0",
    "author": "qpdf contributors",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/qpdf/qpdf.git"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./wasm": "./dist/qpdf.wasm"
    },
    "scripts": {
        "build": "pnpm run build:wasm && pnpm run build:lib",
        "build:lib": "tsdown",
        "build:wasm": "cd wasm && bash build.sh",
        "clean": "rm -rf dist build",
        "format": "oxfmt --write src tsdown.config.ts vitest.config.ts",
        "format:check": "oxfmt --check src tsdown.config.ts vitest.config.ts",
        "lint": "oxlint src tsdown.config.ts vitest.config.ts",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "validate": "publint"
    }
}
