{
    "name": "@pdfly/wasm",
    "version": "0.1.0",
    "description": "Modern WebAssembly build of qpdf for PDF compression and manipulation",
    "keywords": [
        "compression",
        "pdf",
        "pdf-processing",
        "qpdf",
        "wasm",
        "webassembly"
    ],
    "homepage": "https://github.com/MatteoGauthier/qpdf-wasm#readme",
    "bugs": {
        "url": "https://github.com/MatteoGauthier/qpdf-wasm/issues"
    },
    "license": "Apache-2.0",
    "author": "qpdf contributors",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/MatteoGauthier/qpdf-wasm.git",
        "directory": "packages/pdfly-wasm"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "source": "./src/index.ts",
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./render": {
            "source": "./src/render.ts",
            "import": {
                "types": "./dist/render.d.mts",
                "default": "./dist/render.mjs"
            },
            "require": {
                "types": "./dist/render.d.cts",
                "default": "./dist/render.cjs"
            }
        }
    },
    "publishConfig": {
        "exports": {
            ".": {
                "import": {
                    "types": "./dist/index.d.mts",
                    "default": "./dist/index.mjs"
                },
                "require": {
                    "types": "./dist/index.d.cts",
                    "default": "./dist/index.cjs"
                }
            },
            "./render": {
                "import": {
                    "types": "./dist/render.d.mts",
                    "default": "./dist/render.mjs"
                },
                "require": {
                    "types": "./dist/render.d.cts",
                    "default": "./dist/render.cjs"
                }
            }
        }
    },
    "scripts": {
        "build": "pnpm run build:wasm && pnpm run build:lib",
        "build:lib": "tsdown",
        "build:ghostscript:dev": "rm -rf build/ghostscript && docker buildx build --file wasm/docker/ghostscript.Dockerfile --build-arg GHOSTSCRIPT_BUILD_MODE=dev --build-arg JOBS=1 --output type=local,dest=build/ghostscript ../..",
        "build:ghostscript:prd": "rm -rf build/ghostscript && docker buildx build --file wasm/docker/ghostscript.Dockerfile --build-arg GHOSTSCRIPT_BUILD_MODE=prd --build-arg JOBS=1 --output type=local,dest=build/ghostscript ../..",
        "smoke:ghostscript": "node --experimental-strip-types script/ghostscript-smoke.ts",
        "build:wasm": "node script/build-wasm.mjs",
        "clean": "rm -rf dist build",
        "format": "oxfmt --write src tsdown.config.ts vitest.config.ts",
        "format:check": "oxfmt --check src tsdown.config.ts vitest.config.ts",
        "lint": "oxlint src tsdown.config.ts vitest.config.ts",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest",
        "typecheck": "tsgo --noEmit",
        "validate": "publint && attw --pack . --profile node16",
        "package:check": "pnpm run validate && pnpm pack --dry-run"
    },
    "devDependencies": {
        "@arethetypeswrong/cli": "^0.18.2",
        "@arethetypeswrong/core": "^0.18.2",
        "@types/node": "^25.6.0",
        "@typescript/native-preview": "7.0.0-dev.20260505.1",
        "@vitest/coverage-v8": "^4.1.5",
        "oxfmt": "^0.48.0",
        "oxlint": "^1.63.0",
        "publint": "^0.3.19",
        "tsdown": "^0.21.10",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5"
    },
    "peerDependencies": {
        "canvas": "^3.2.3",
        "pdfjs-dist": "^5.7.284"
    },
    "peerDependenciesMeta": {
        "canvas": {
            "optional": true
        },
        "pdfjs-dist": {
            "optional": true
        }
    },
    "engines": {
        "node": ">=24.0.0"
    }
}
