{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"]
        },
        "build:types": {
            "outputs": ["dist/**/*.d.*"]
        },
        "clean": {
            "cache": false
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "format": {
            "cache": false
        },
        "lint": {},
        "test": {},
        "test:watch": {
            "cache": false,
            "persistent": true
        },
        "typecheck": {
            "dependsOn": ["^build:types"]
        },
        "validate": {
            "dependsOn": ["build"]
        }
    }
}
