{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"]
        },
        "build:lib": {
            "outputs": ["dist/**"],
            "inputs": ["src/**", "tsdown.config.ts", "tsconfig.json"]
        },
        "clean": {
            "cache": false
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "format": {
            "cache": false
        },
        "lint": {
            "inputs": ["src/**", "*.config.ts"]
        },
        "test": {
            "inputs": ["src/**", "vitest.config.ts"]
        },
        "test:watch": {
            "cache": false,
            "persistent": true
        },
        "typecheck": {
            "dependsOn": ["^typecheck"],
            "inputs": ["src/**", "tsconfig.json"]
        },
        "validate": {
            "dependsOn": ["build"]
        }
    }
}
